# ── App ────────────────────────────────────────────────────────────────────
APP_NAME=CareGuard
APP_VERSION=0.1.0
ENVIRONMENT=development           # development | production
BASE_URL=https://api.careguard.health
DOMAIN=api.careguard.health

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/careguard

# ── AWS ─────────────────────────────────────────────────────────────────────
# Sign HIPAA BAA at: https://aws.amazon.com/artifact/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=careguard-discharge-docs
SNS_ESCALATION_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:careguard-escalations

# ── LLM provider ────────────────────────────────────────────────────────────
# Which model powers the care agent. Switch providers without code changes.
LLM_PROVIDER=claude              # claude | deepseek
LLM_MAX_TOKENS=500

# ── Anthropic (used when LLM_PROVIDER=claude) ───────────────────────────────
# Sign HIPAA BAA at: https://www.anthropic.com/hipaa
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# ── DeepSeek (used when LLM_PROVIDER=deepseek) ──────────────────────────────
# Get API key at: https://platform.deepseek.com/api_keys
# NOTE: DeepSeek does not currently offer a HIPAA BAA — do not send PHI
# through DeepSeek in production until a BAA is in place.
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat     # deepseek-chat | deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Twilio ──────────────────────────────────────────────────────────────────
# Sign HIPAA BAA at: https://www.twilio.com/en-us/hipaa
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# ── Epic FHIR ───────────────────────────────────────────────────────────────
# Register at: https://open.epic.com
# Sandbox base URL: https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
EPIC_CLIENT_ID=your-epic-client-id
EPIC_PRIVATE_KEY_PATH=/path/to/your/private-key.pem   # NEVER commit the actual key file

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-strong-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── Celery / SQS ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=sqs://
CELERY_RESULT_BACKEND=redis://localhost:6379/0
